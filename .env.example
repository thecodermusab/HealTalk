# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Agora (Video Calling)
AGORA_APP_ID="your-agora-app-id"
AGORA_APP_CERTIFICATE="your-agora-certificate"

# Google Gemini (AI Chatbot) - REQUIRED FOR MENTAL HEALTH SCREENING - 100% FREE
GEMINI_API_KEY="AIza..." # Get from https://makersuite.google.com/app/apikey

# Alternative: OpenAI (paid, $0.01-0.05 per assessment)
# OPENAI_API_KEY="sk-..." # Get from https://platform.openai.com/api-keys

# Resend (Email)
RESEND_API_KEY="re_..."

# UploadThing (File Uploads)
UPLOADTHING_SECRET="sk_..."
UPLOADTHING_APP_ID="..."

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (Phase 2 auth migration - optional)
SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="ey..."
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="ey..."
SUPABASE_AUTH_MIGRATION_ENABLED="false"

# Auth cutover mode: nextauth | hybrid | supabase_first
AUTH_CUTOVER_MODE="nextauth"
NEXT_PUBLIC_AUTH_CUTOVER_MODE="nextauth"
